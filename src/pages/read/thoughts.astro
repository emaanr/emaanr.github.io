---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import BreadcrumbsLayout from "@layouts/BreadcrumbsLayout.astro";
import ThoughtsLayout from "@layouts/ThoughtsLayout.astro";

const thoughts = await getCollection("readThoughts");
---

<Layout>
  <div id="posts">
    <BreadcrumbsLayout>
      <ThoughtsLayout thoughts={thoughts} />
    </BreadcrumbsLayout>
  </div>
</Layout>
