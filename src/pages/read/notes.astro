---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import BreadcrumbsLayout from "@layouts/BreadcrumbsLayout.astro";
import PostsLayout from "@layouts/PostsLayout.astro";

const posts = await getCollection("readNotes");
---

<Layout>
  <div id="posts">
    <BreadcrumbsLayout>
      <PostsLayout posts={posts} path="notes" />
    </BreadcrumbsLayout>
  </div>
</Layout>
