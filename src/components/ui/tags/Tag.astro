---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span class="tag">{tag}</span>

<style>
  .tag {
    display: inline-block;
    padding: 0 0.25rem;
    font-size: 0.75rem;
    border-radius: 3px;
    color: var(--black);
    background: var(--ink-300);
    white-space: nowrap;
  }
</style>
