---
interface Props {
  tag: string;
  href?: string;
}

const { tag, href } = Astro.props;
---

{
  href ? (
    <a class="tag clickable" href={href} target="_blank" rel="noopener noreferrer">
      {tag}
    </a>
  ) : (
    <span class="tag">{tag}</span>
  )
}

<style>
  .tag {
    display: inline-block;
    padding: 0 0.25rem;
    font-size: 0.75rem;
    border-radius: 3px;
    color: var(--black);
    background: var(--ink-300);
    white-space: nowrap;
  }

  .clickable {
    background: var(--red-500);
    cursor: pointer;
  }

  .clickable:hover {
    background: var(--red-600);
  }
</style>
